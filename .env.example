# Copy this file to .env and fill in the values.

# Frontend
PUBLIC_API_URL=https://your-domain.example.com/api
PUBLIC_TILE_SERVER_URL=https://your-domain.example.com/tiles

# Backend
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
REDIRECT_URI=https://your-domain.example.com/api/auth/strava/callback
WEBHOOK_URI=https://your-domain.example.com/api/webhook
VERIFY_TOKEN=a_random_string_you_choose
DATABASE_PATH=postgres://postgres:your_postgres_password@postgis:5432/wanderwell?sslmode=disable
SERVER_PORT=:3000
FRONTEND_URL=https://your-domain.example.com
SESSION_SECRET=a_long_random_secret
SESSION_KEY=another_long_random_secret

# Postgis
POSTGRES_PASSWORD=your_postgres_password

# Vinyl cache settings
VINYL_PURGE_URL=http://vinylcache:80/purge
VINYL_ADMIN_KEY=
VINYL_CACHE_SIZE=1GB

# Production deployment (used by docker-compose.prod.yml)
ACME_EMAIL=your-email@example.com
DOMAIN=your-domain.example.com
